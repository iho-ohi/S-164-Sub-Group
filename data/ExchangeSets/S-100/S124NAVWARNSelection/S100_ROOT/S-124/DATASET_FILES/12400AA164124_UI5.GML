        <S124:NavwarnPart gml:id="WZ-348-2026-PART-1">
            <S124:warningInformation>
                <S124:information>
                    <S124:language>eng</S124:language>
                    <S124:text>LIVE WEAPON FIRINGS IN PROGRESS DAILY BETWEEN 0800 AND 1500 UTC FROM 02 TO 05 JUN IN AREA WITHIN 16.5 MILES OF 52-26.7N 004-44.6W. THIS IS AN EXTREMELY HAZARDOUS AREA AND MARINERS ARE REQUESTED TO VACATE THE AREA DURING THE ABOVE PERIODS. ANY VESSELS INTENDING TO ENTER THE AREA SHOULD CONTACT ABERPORTH MARINE CONTROL ON VHF CH16 OR TELEPHONE NUMBER +441239813480 OR +447495043213 (OUT OF HOURS).</S124:text>
                </S124:information>
                <S124:navwarnTypeDetails code="120">Firing Exercise</S124:navwarnTypeDetails>
            </S124:warningInformation>
            <S124:fixedDateRange>
                <S124:dateStart>20260602</S124:dateStart>
                <S124:dateEnd>20260605</S124:dateEnd>
                <S124:timeOfDayStart>080000</S124:timeOfDayStart>
